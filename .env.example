# Database
DATABASE_URL="postgresql://user:password@localhost:5432/heretix_management"

# NextAuth secret (generate with: openssl rand -base64 32)
AUTH_SECRET=

# heretix-api connection
# These can also be configured via the Settings page and stored in the database.
# Environment variables are used as fallback when no DB value is set.
HERETIX_API_URL="http://localhost:5000"
HERETIX_API_KEY=  # must match API_KEY in heretix-api .env; leave empty if auth disabled

# Cron schedules (cron syntax, UTC)
# Default: refresh at 12:00, scan at 13:00
CRON_REFRESH="0 12 * * *"
CRON_SCAN="0 13 * * *"
